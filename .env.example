# ============================================================
# AMJ HUB — Environment Variables
# ============================================================
# Copy this file to ".env" and fill in real values, OR set these
# as environment variables on your hosting platform (Render,
# Railway, a VPS systemd service, Docker, etc).
#
# IMPORTANT: This file is loaded via the OS environment, not
# automatically by Go. See README.md "Setting Environment
# Variables" for how to load it locally.
# ============================================================

# ---- Recipient ----
# The inbox that receives every contact form submission.
# This is the ONLY value most clients will ever need to change.
CONTACT_RECIPIENT_EMAIL=info@amjhub.com

# ---- SMTP Server ----
# Examples:
#   Gmail:        smtp.gmail.com   port 587  (requires an "App Password", not your normal password)
#   Outlook/365:  smtp.office365.com  port 587
#   Zoho Mail:    smtp.zoho.com    port 587
#   SendGrid:     smtp.sendgrid.net  port 587 (username is literally "apikey")
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ---- SMTP Authentication ----
# The account used to actually send the email (logs into the SMTP server).
SMTP_USERNAME=your-sending-account@gmail.com
SMTP_PASSWORD=your-app-password-here

# ---- Optional: "From" address shown to the recipient ----
# If left blank, SMTP_USERNAME is used as the From address.
EMAIL_FROM=info@amjhub.com
